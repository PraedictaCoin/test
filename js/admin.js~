async function adminAction(action, params = {}) {
    try {
        const result = await callSecureRpc('admin_action', { action, params });
        const resultContainer = document.getElementById('adminResult');
        if (result?.data) {
            resultContainer.innerHTML = `
                <div class="card" style="border:1px solid var(--success-color);">
                    <pre style="font-size:.7rem;overflow-x:auto;color:var(--text);">${escapeHtml(JSON.stringify(result.data, null, 2))}</pre>
                </div>
            `;
        } else {
            resultContainer.innerHTML = '';
        }
        showToast('Done!', 'success');
        await loadAdminDashboard(); // refresh after action
    } catch (err) {
        showToast('Failed: ' + err.message, 'error');
    }
}

function adminResolvePrompt() {
    const id = sanitize(prompt("Prediction ID:"), 50);
    if (!id) return;
    const outcome = prompt("Outcome (yes/no/unresolvable):");
    if (!outcome) return;
    adminAction('force_resolve', { predictionId: id, outcome });
}

function adminDeletePrompt() {
    const id = sanitize(prompt("Prediction ID to DELETE:"), 50);
    if (!id) return;
    if (!confirm(`DELETE prediction ${id}?`)) return;
    adminAction('delete_prediction', { predictionId: id });
}

function adminBanPrompt() {
    const wallet = sanitize(prompt("Wallet to BAN:"), 50);
    if (!wallet) return;
    if (!confirm(`BAN wallet ${wallet}?`)) return;
    adminAction('ban_user', { targetWallet: wallet });
}

function adminDeleteUserDataPrompt() {
    const wallet = sanitize(prompt("Enter wallet address to DELETE ALL DATA (predictions, bets, orders, etc.):"), 50);
    if (!wallet) return;
    if (!confirm(`⚠️ PERMANENT ACTION: This will delete ALL predictions, bets, orders, fills, watchlist, and profile data for wallet ${wallet}. This cannot be undone. Continue?`)) return;
    adminAction('delete_user_data', { targetWallet: wallet });
}

async function adminSearchUser() {
    const query = document.getElementById('adminUserSearch')?.value;
    if (!query) return;
    const resultContainer = document.getElementById('adminUserResult');
    resultContainer.innerHTML = '<div class="card">Loading...</div>';
    try {
        const result = await callSecureRpc('admin_action', { action: 'search_user', params: { query } });
        if (result.error) throw new Error(result.error);
        if (!result.data || result.data.length === 0) {
            resultContainer.innerHTML = '<div class="card">No users found.</div>';
            return;
        }
        // Display users in a table
        let html = '<div class="card"><h3 style="color:var(--accent);">Search Results</h3><div style="overflow-x:auto;"><table style="width:100%; border-collapse:collapse; font-size:.8rem;">';
        html += '<thead><tr><th style="text-align:left;">Wallet</th><th>Display Name</th><th>Balance</th><th>SeerScore</th><th>Email</th><th>Banned</th></tr></thead><tbody>';
        for (const u of result.data) {
            html += `<tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:4px;">${escapeHtml(u.address.slice(0,8))}...</td>
                        <td style="padding:4px;">${escapeHtml(u.display_name || '-')}</td>
                        <td style="padding:4px;">${u.prae_balance || 0}</td>
                        <td style="padding:4px;">${u.seerscore || 0}</td>
                        <td style="padding:4px;">${u.email ? (u.email_verified ? '✅' : '❌') : '-'}</td>
                        <td style="padding:4px;">${u.banned ? '🚫 Yes' : '❌ No'}</td>
                     </tr>`;
        }
        html += '</tbody></table></div></div>';
        resultContainer.innerHTML = html;
    } catch (err) {
        resultContainer.innerHTML = `<div class="card">Error: ${err.message}</div>`;
    }
}

function exportAdminCSV() {
    const { topSeers = [], recentActivity = [] } = adminData;
    let csv = 'type,address,name,seerscore,title,status,created\n';
    
    const escapeCSV = (str) => {
        if (str === undefined || str === null) return '';
        str = String(str);
        str = str.replace(/"/g, '""');
        return `"${str}"`;
    };
    
    topSeers.forEach(u => {
        csv += `seer,${escapeCSV(u.address)},${escapeCSV(u.display_name)},${u.seerscore || 0},,,,,\n`;
    });
    recentActivity.forEach(p => {
        csv += `prediction,${escapeCSV(p.creator)},,${escapeCSV(p.title)},${p.status},${p.created_at},\n`;
    });
    
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `praedicta-admin-${getUTCDayKey()}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('📥 CSV exported!', 'success');
}