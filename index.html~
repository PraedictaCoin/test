    <title>PRAEDICTA – For Those Who See</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='50' fill='%2300F0FF'/><text x='50' y='67' text-anchor='middle' fill='%230A0A0A' font-size='50' font-weight='bold'>P</text></svg>">
    <link rel="manifest" href="data:application/manifest+json,{%22name%22:%22PRAEDICTA%22,%22short_name%22:%22PRAEDICTA%22,%22start_url%22:%22.%22,%22display%22:%22standalone%22,%22background_color%22:%22%230A0A0A%22,%22theme_color%22:%22%2300F0FF%22,%22icons%22:[{%22src%22:%22data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='50' fill='%2300F0FF'/%3E%3Ctext x='50' y='67' text-anchor='middle' fill='%230A0A0A' font-size='50' font-weight='bold'%3EP%3C/text%3E%3C/svg%3E%22,%22sizes%22:%22any%22}]}">
    <!-- Lightweight-charts and Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/lightweight-charts@5.2.0/dist/lightweight-charts.standalone.js"></script>
    
     <style>
        /* ========== FULL CSS (turquoise default + violet option) ========== */
        :root {
            --bg: #0A0A0A; --text: #FFFFFF; --accent: #00F0FF;
            --accent-glow: rgba(0, 240, 255, 0.3); --border: rgba(0, 240, 255, 0.1);
            --card-bg: rgba(0, 240, 255, 0.03); --card-border: rgba(0, 240, 255, 0.1);
            --text-muted: #8A8A8A; --text-secondary: #ccc;
            --stat-bg: rgba(0, 240, 255, 0.05);
            --input-bg: #2a1f0a; --input-border: #4a3a1a;
            --oracle-color: #FFB800;
            --challenge-bg: rgba(255,215,0,0.1); --challenge-border: #FFD700;
            --flash-bg: rgba(255,69,0,0.1); --flash-border: #FF4500;
            --badge-resolved: #aa66ff;
            --select-option-bg: #0A0A0A;
        }
        body.violet {
            --accent: #7C3AED;
            --accent-glow: rgba(124, 58, 237, 0.3);
            --border: rgba(124, 58, 237, 0.1);
            --card-bg: rgba(124, 58, 237, 0.03);
            --card-border: rgba(124, 58, 237, 0.1);
            --stat-bg: rgba(124, 58, 237, 0.05);
            --badge-resolved: #A78BFA;
        }
        body.light {
            --bg: #FFFFFF; --text: #1A1A2E; --accent: #62A29B;
            --accent-glow: rgba(98, 162, 155, 0.3); --border: rgba(98, 162, 155, 0.3);
            --card-bg: rgba(98, 162, 155, 0.05); --card-border: rgba(98, 162, 155, 0.2);
            --text-muted: #62A29B; --text-secondary: #8A8A8A;
            --stat-bg: rgba(98, 162, 155, 0.08);
            --input-bg: #fcf5e6; --input-border: #d4c29a;
            --oracle-color: #FFB800;
            --challenge-bg: rgba(255,215,0,0.05); --challenge-border: #DAA520;
            --flash-bg: rgba(255,69,0,0.05); --flash-border: #FF4500;
            --badge-resolved: #aa66ff;
            --select-option-bg: #FFFFFF;
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; transition: background-color .4s ease, color .4s ease, border-color .4s ease, box-shadow .4s ease; }
        body { background: var(--bg); color: var(--text); font-family: 'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; overflow-x: hidden; font-size:16px; }

        .btn { padding:12px 28px; border-radius:50px; font-size:.8rem; font-weight:500; letter-spacing:2px; text-transform:uppercase; background:var(--accent); color:var(--bg); border:none; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; gap:8px; }
        .btn:disabled { opacity:.5; cursor:not-allowed; }
        .btn-secondary { background:transparent; color:var(--accent); border:1px solid var(--accent); }
        .card { background:var(--card-bg); border:1px solid var(--card-border); border-radius:20px; padding:20px; margin-bottom:20px; }
        .card:hover { border-color:var(--accent-glow); }

        .gate { position:fixed; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; z-index:1000; background:var(--bg); }
        .gate-card { background:var(--card-bg); border:1px solid var(--accent-glow); border-radius:48px; padding:40px; max-width:450px; width:90%; text-align:center; backdrop-filter:blur(4px); }
        .eye-container { width:100px; height:64px; margin:0 auto 24px; }
        .eye { width:100%; height:100%; border:2px solid var(--accent); border-radius:50%; position:relative; overflow:hidden; animation:blink 4s ease-in-out infinite; display:flex; align-items:center; justify-content:center; background:var(--bg); }
        .iris { width:45px; height:45px; background:radial-gradient(circle,#2D0B4F 0%,#6B2FA0 40%,var(--accent) 70%,var(--accent) 100%); border-radius:50%; animation:pulse 3s ease-in-out infinite; }
        .pupil { width:18px; height:18px; background:var(--bg); border-radius:50%; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); }
        .gate-card h2 { font-size:2rem; font-weight:300; letter-spacing:6px; color:var(--accent); margin-bottom:8px; }
        .gate-card .tagline { color:var(--text-muted); font-size:.8rem; letter-spacing:3px; margin-bottom:24px; }

        .main-app { display:none; max-width:1400px; margin:0 auto; padding:20px 24px; }
        .app-header { background:var(--card-bg); border:1px solid var(--card-border); border-radius:24px; padding:20px; margin-bottom:30px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px; }
        .logo-area { display:flex; align-items:center; gap:16px; }
        .logo-eye { width:50px; height:32px; }
        .logo-eye .eye { width:100%; height:100%; border-width:1px; }
        .logo-eye .iris { width:22px; height:22px; }
        .logo-eye .pupil { width:8px; height:8px; }
        .logo-area h1 { font-size:1.8rem; font-weight:300; letter-spacing:6px; color:var(--accent); }
        .logo-area .tagline { font-size:.7rem; letter-spacing:2px; color:var(--text-muted); }
        .stats { display:flex; gap:20px; align-items:center; flex-wrap:wrap; }
        .stat { background:var(--stat-bg); padding:8px 20px; border-radius:40px; text-align:center; }
        .stat-value { font-size:1.5rem; font-weight:600; color:var(--accent); }

        .tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:24px; align-items:center; justify-content:space-between; }
        .tabs-left { display:flex; gap:8px; flex-wrap:wrap; }
        .tab-btn { background:transparent; border:1px solid var(--accent-glow); padding:8px 20px; border-radius:40px; cursor:pointer; color:var(--text-muted); font-size:.8rem; letter-spacing:1px; }
        .tab-btn.active { background:var(--accent); color:var(--bg); border-color:var(--accent); }
        .right-tab-items { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
        .icon-btn { background:transparent; border:1px solid var(--accent); border-radius:40px; padding:8px 16px; cursor:pointer; color:var(--accent); font-size:.8rem; text-decoration:none; display:inline-flex; align-items:center; gap:6px; }
        .icon-btn:hover { background:var(--accent-glow); }
        .oracle-indicator-top { background:rgba(255,184,0,0.2); border:1px solid var(--oracle-color); border-radius:40px; padding:6px 14px; font-size:.7rem; color:var(--oracle-color); display:inline-flex; align-items:center; gap:6px; }
        .tab-content { display:none; }
        .tab-content.active { display:block; }

        .filter-bar { display:flex; gap:12px; flex-wrap:wrap; margin-top:16px; margin-bottom:24px; align-items:center; }
        .filter-bar select, .filter-bar input, input[type="text"], textarea, select { background:var(--input-bg); border:1px solid var(--input-border); border-radius:40px; padding:8px 16px; color:var(--text); font-size:.8rem; }
        .filter-bar select option, select option { background:var(--select-option-bg); color:var(--text); }
        .status-filter-btns { display:flex; gap:8px; }
        .status-filter-btn { background:transparent; border:1px solid var(--accent-glow); padding:8px 16px; border-radius:40px; cursor:pointer; color:var(--text-muted); font-size:.75rem; }
        .status-filter-btn.active-filter { background:var(--accent-glow); color:var(--accent); border-color:var(--accent); }
        .category-carousel { display:flex; gap:8px; overflow-x:auto; padding:8px 0; margin-bottom:16px; }
        .category-carousel-btn { background:transparent; border:1px solid var(--accent-glow); padding:8px 16px; border-radius:40px; cursor:pointer; color:var(--text-muted); font-size:.75rem; white-space:nowrap; }
        .category-carousel-btn.active-filter { background:var(--accent-glow); color:var(--accent); border-color:var(--accent); }

        .praedictions-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(360px,1fr)); gap:20px; margin-bottom:30px; }
        .praediction-card { background:var(--card-bg); border:1px solid var(--card-border); border-radius:20px; padding:20px; position:relative; }
        .praediction-card:hover { border-color:var(--accent-glow); }
        .praediction-title { font-size:1.2rem; font-weight:500; color:var(--accent); margin-bottom:8px; word-break:break-word; }
        .praediction-desc { font-size:.9rem; margin-bottom:12px; color:var(--text-secondary); word-break:break-word; }
        .meta-row { display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:8px; font-size:.7rem; color:var(--text-muted); border-top:1px solid var(--accent-glow); padding-top:8px; margin-bottom:12px; }

        .badge { display:inline-block; padding:2px 8px; border-radius:20px; font-size:.7rem; font-weight:500; }
        .badge-active { background:rgba(0,240,255,0.2); color:var(--accent); border:1px solid var(--accent); }
        .badge-resolved { background:rgba(170,102,255,0.2); color:var(--badge-resolved); border:1px solid var(--badge-resolved); }
        .badge-expired { background:rgba(255,68,68,0.2); color:#FF8888; border:1px solid #FF8888; }
        .badge-controversy { background:rgba(255,105,180,0.2); color:#FF69B4; border:1px solid #FF69B4; }
        .badge-flash { background:rgba(255,69,0,0.2); color:#FF4500; border:1px solid #FF4500; }
        .oracle-badge { background:rgba(255,184,0,0.2); color:var(--oracle-color); border:1px solid var(--oracle-color); }

        .vote-stats { display:flex; justify-content:space-between; background:var(--accent-glow); border-radius:40px; padding:8px 16px; font-size:.7rem; font-weight:500; }
        .action-buttons { display:flex; gap:12px; margin-top:16px; flex-wrap:wrap; }
        .btn-praedict, .btn-suggest { padding:8px 16px; border-radius:40px; font-weight:500; font-size:.8rem; cursor:pointer; flex:1; text-align:center; display:inline-flex; align-items:center; justify-content:center; gap:6px; }
        .btn-praedict { background:var(--accent); color:var(--bg); border:none; }
        .btn-praedict:disabled { opacity:.5; }
        .btn-suggest { background:rgba(0,240,255,0.2); color:var(--accent); border:1px solid var(--accent); }
        .oracle-resolve { background:var(--oracle-color); color:#FFF; border:none; padding:8px; border-radius:40px; font-weight:600; cursor:pointer; margin-top:8px; width:100%; display:inline-flex; align-items:center; justify-content:center; gap:6px; }
        .loader { display:inline-block; width:14px; height:14px; border:2px solid rgba(255,255,255,0.3); border-radius:50%; border-top-color:currentColor; animation:spin .6s linear infinite; }

        .create-praediction input, .create-praediction textarea, .create-praediction select { width:100%; padding:10px; margin-bottom:12px; background:var(--input-bg); border:1px solid var(--input-border); border-radius:12px; color:var(--text); font-family:inherit; }
        .social-btn { background:rgba(0,240,255,0.1); color:var(--accent); padding:6px 12px; border-radius:40px; text-decoration:none; font-size:.8rem; border:1px solid var(--accent-glow); display:inline-block; }
        .social-btn:hover { background:var(--accent-glow); }

        .toast { position:fixed; bottom:20px; right:20px; padding:12px 24px; border-radius:40px; font-weight:bold; z-index:1000; animation:fadeIn .3s; background:var(--accent); color:var(--bg); }
        .skeleton { background:linear-gradient(90deg,var(--card-bg) 25%,var(--accent-glow) 50%,var(--card-bg) 75%); background-size:200% 100%; animation:shimmer 1.5s infinite; border-radius:12px; }
        .resolution-info { margin-top:12px; padding:12px; background:var(--accent-glow); border-radius:12px; font-size:.75rem; }
        .offline-banner { display:none; background:#FF4444; color:#FFF; text-align:center; padding:8px; border-radius:12px; margin-bottom:16px; }
        .empty-state { text-align:center; padding:40px 20px; color:var(--text-muted); }
        .empty-state-icon { font-size:3rem; margin-bottom:12px; }
        .price-highlight { background: linear-gradient(135deg, var(--accent), var(--oracle-color)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 700; }
        #creatorBetYes.selected { box-shadow: 0 0 15px rgba(0,240,255,0.6); border: 2px solid var(--accent); }
        #creatorBetNo.selected { box-shadow: 0 0 15px rgba(239,68,68,0.6); border: 2px solid #EF4444; }
        #particlesCanvas { position:fixed; top:0; left:0; z-index:-1; pointer-events:none; opacity:0.6; }
        body.light #particlesCanvas { opacity:0.35; }
        .user-profile-link { cursor:pointer; }
        .filter-tag { font-size:.6rem;padding:2px 8px;border-radius:12px;background:var(--card-bg);border:1px solid var(--border);cursor:pointer;color:var(--text-muted);}
        .filter-tag.active-filter { background:var(--accent-glow);color:var(--accent);border-color:var(--accent); }

        .profile-section { border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:12px;background:var(--card-bg);cursor:pointer; }
        .profile-section:hover { border-color:var(--accent); }
        .profile-section-header { display:flex;justify-content:space-between;align-items:center;color:var(--text);font-size:.9rem; }
        .profile-section-content { max-height:0;overflow:hidden;transition:max-height 0.4s ease; }
        .profile-section-content.open { max-height:2000px;margin-top:12px; }
        .section-toggle-icon { font-size:.8rem; }

        @keyframes fadeIn { from{opacity:0;transform:translateX(100%)} to{opacity:1;transform:translateX(0)} }
        @keyframes blink { 0%,90%,100%{transform:scaleY(1)} 95%{transform:scaleY(.1)} }
        @keyframes pulse { 0%,100%{opacity:.6} 50%{opacity:1} }
        @keyframes spin { to{transform:rotate(360deg)} }
        @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
        @keyframes glow { from{background:var(--accent-glow)} to{background:transparent} }
        .leaderboard-glow { animation: glow 1.5s ease-out; }

        @media(max-width:768px) {
            .app-header{flex-direction:column;align-items:flex-start}
            .stats{width:100%;justify-content:space-between;margin-top:16px}
            .tabs{flex-direction:column;align-items:stretch}
            .tabs-left{justify-content:space-between}
            .right-tab-items{justify-content:space-between}
            .praedictions-grid{grid-template-columns:1fr}
            .create-praediction-wrapper{position:relative}
            .create-praediction{max-height:0;overflow:hidden;transition:max-height 0.4s ease;margin-bottom:0;padding:0 20px;border:none}
            .create-praediction.expanded{max-height:900px;margin-bottom:20px;padding:20px;border:1px solid var(--card-border)}
            .create-fab{position:fixed;bottom:20px;right:20px;width:56px;height:56px;border-radius:50%;background:var(--accent);color:var(--bg);border:none;font-size:1.5rem;cursor:pointer;z-index:100;box-shadow:0 4px 20px rgba(0,240,255,0.4);display:flex;align-items:center;justify-content:center}
            .create-fab.active{transform:rotate(45deg)}
        }
        @media(min-width:769px) {
            .create-fab{display:none!important}
            .create-praediction{max-height:none!important;overflow:visible!important}
        }
    </style>
</head>
<body>

<canvas id="particlesCanvas"></canvas>

<button id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" style="position:fixed;bottom:20px;left:20px;width:40px;height:40px;border-radius:50%;background:var(--accent);color:var(--bg);border:none;cursor:pointer;z-index:100;display:none;font-size:1.2rem;">↑</button>

<div id="notifCenter" style="display:none;position:fixed;top:80px;right:20px;width:360px;max-width:90vw;max-height:70vh;background:var(--bg);border:2px solid var(--accent);border-radius:20px;z-index:4000;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.5);">
    <div style="padding:16px;position:sticky;top:0;background:var(--bg);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
        <h3 style="color:var(--accent);">🔔 Notifications</h3>
        <button onclick="clearAllNotifs()" style="background:transparent;border:none;color:var(--text-muted);cursor:pointer;font-size:.7rem;">Clear all</button>
    </div>
    <div id="notifList" style="padding:8px 16px;"></div>
</div>

<div id="tutorialOverlay" style="display:none;">
    <div class="tutorial-card overlay-message" style="position:static;transform:none;">
        <div class="eye-container" style="width:80px;height:50px;margin:0 auto 16px;"><div class="eye"><div class="iris"><div class="pupil"></div></div></div></div>
        <h2 style="color:var(--accent);">Welcome to P R A E D I C T A</h2>
        <p style="margin:16px 0;line-height:1.6;">✨ Create predictions about future events<br>💰 Commit YES or NO with virtual points<br>🤖 46+ APIs auto-resolve outcomes<br>📎 Source URL required for manual resolution</p>
        <button id="closeTutorialBtn" class="btn">Let's go!</button>
    </div>
</div>

<div id="gate" class="gate">
    <div class="gate-card">
        <div class="eye-container"><div class="eye"><div class="iris"><div class="pupil"></div></div></div></div>
        <h2>PRAEDICTA</h2><div class="tagline">for those who see</div>
        <div class="age-consent" style="margin:16px 0;">
            <input type="checkbox" id="ageCheckbox" aria-label="Age confirmation">
            <label for="ageCheckbox">I am 18+ and understand this is a <strong>free prediction game</strong>. Virtual points only. <a href="#" class="legal-link" data-doc="terms" style="color:var(--accent);">Game Rules</a></label>
        </div>
        <input type="email" id="emailInput" placeholder="Email for notifications (optional)" style="width:100%; padding:12px; background:var(--input-bg); border:1px solid var(--input-border); border-radius:40px; color:var(--text); text-align:center; font-size:.8rem; margin-bottom:12px;" autocomplete="email">
        <button id="connectBtn" class="btn"><span>Connect Wallet</span><span class="loader" style="display:none;"></span></button>
        <p style="color:var(--text-muted); font-size:.7rem; margin-top:8px;">🔐 Free to play – no real money involved</p>
        <p style="color:var(--text-muted); font-size:.65rem; margin-top:4px;">Virtual points for entertainment only · No cash value · Cannot be withdrawn</p>
        <div id="gateMessage" style="margin-top:20px; color:#8A8A8A;"></div>
        <div id="emailVerifySection" style="display:none; margin-top:12px; padding:12px; background:var(--accent-glow); border-radius:12px;">
            <p style="font-size:.8rem;color:var(--accent);">📧 Verify your email for notifications</p>
            <div style="display:flex;gap:8px;margin-top:8px;">
                <input type="text" id="emailVerifyCode" placeholder="Enter 6-digit code" maxlength="6" style="flex:1; text-align:center; letter-spacing:4px; background:var(--input-bg); border:1px solid var(--input-border); border-radius:40px; padding:8px 16px; color:var(--text);">
                <button id="verifyEmailBtn" class="btn" style="font-size:.7rem;">Verify</button>
            </div>
            <button id="sendVerifyEmailBtn" class="btn" style="width:100%;margin-top:8px;font-size:.7rem;background:var(--card-bg);color:var(--accent);border:1px solid var(--accent);">Send Verification Code</button>
        </div>
    </div>
</div>

<div id="mainApp" class="main-app">
    <header class="app-header" role="banner">
        <div class="logo-area">
            <div class="logo-eye" id="logoEyeWrapper" aria-hidden="true"><div class="eye"><div class="iris"><div class="pupil"></div></div></div></div>
            <div><h1>PRAEDICTA</h1><div class="tagline">for those who see</div></div>
        </div>
        <!-- Stats bar removed (moved to Support tab) -->
    </header>

    <div id="offlineBanner" class="offline-banner" onclick="refreshAll()">⚠️ Connection lost. Tap to retry.</div>

    <nav class="tabs" role="tablist">
        <div class="tabs-left">
            <button class="tab-btn active" data-tab="praedictions">🌌 Praedictions</button>
            <button class="tab-btn" data-tab="leaderboard">🏆 Leaderboard</button>
            <button class="tab-btn" data-tab="watchlist">⭐ Watchlist</button>
            <button class="tab-btn" data-tab="expired">🕒 Expired</button>
            <button class="tab-btn" data-tab="profile">👤 Profile</button>
